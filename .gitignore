# Transient checkout of the master/source repo used during CI builds
/_master/

# Python environment & caches
.venv/
.direnv/
__pycache__/
*.py[cod]
*.pytest_cache/
.ipynb_checkpoints/

# Environment & secrets
.env
secrets.toml
id_rsa
id_rsa.pub

# IDE & editor
.vscode/

# Models, data, media, logs (large / generated at runtime)
models/
*.pth
wandb/
*videos
*logs

